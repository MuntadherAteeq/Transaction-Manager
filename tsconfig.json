{
  "extends": "@electron-toolkit/tsconfig/tsconfig.json",
  "exclude": [
    "src/renderer/src/Tools/jQuery.js",
    "src/renderer/src/Tools/jquery-ui.js",
    "src/renderer/src/Tools/pouchdb-8.0.1.js"
  ],
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/preload/*.d.ts"
  ],
  "compilerOptions": {
    "verbatimModuleSyntax": true,
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "allowJs": true,
    "checkJs": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["electron-vite/node", "jquery", "jqueryui","pouchdb"]
  },
  "references": [{ "path": "./tsconfig.node.json" }]
}
